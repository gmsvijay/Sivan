{
  "title": "நமச்சிவாயப் பதிகம் (சொற்றுணை வேதியன்)",
  "author": "திருநாவுக்கரசர் (அப்பர்)",
  "pann": "காந்தார பஞ்சமம்",
  "context": "தருமசேனராக இருந்த அப்பர் பெருமானைக் கல்லோடு பிணைத்துக் கடலில் இட்டபோது பாடியது.",
  "verses": [
    {
      "number": 1,
      "line1": "சொற்றுணை வேதியன் சோதி வானவன்",
      "line2": "பொற்றுணை திருந்தடி பொருந்தக் கைதொழக்",
      "line3": "கற்றுணைப் பூட்டியோர் கடலில் பாய்ச்சினும்",
      "line4": "நற்றுணை யாவது நமச்சி வாயவே."
    },
    {
      "number": 2,
      "line1": "பூவினுக் கருங்கலம் பொங்கு தாமரை",
      "line2": "ஆவினுக் கருங்கலம் அரனஞ் சாடுதல்",
      "line3": "கோவினுக் கருங்கலம் கோட்ட மில்லது",
      "line4": "நாவினுக் கருங்கலம் நமச்சி வாயவே."
    },
    {
      "number": 3,
      "line1": "விண்ணுற அடுக்கிய விறகின் வெந்தழல்",
      "line2": "உண்ணிய புகிலவை ஒன்றும் இல்லையாம்",
      "line3": "பண்ணிய உலகினில் பயின்ற பாவத்தை",
      "line4": "நண்ணிநின் றறுப்பது நமச்சி வாயவே."
    },
    {
      "number": 4,
      "line1": "இடுக்கண் பட்டிருக்கினும் இரந்து யாரையும்",
      "line2": "விடுக்கப் பிராகிலார் வீரன் பெய்கழல்",
      "line3": "அடுத்தநற் சார்பது வாக அத்தகு",
      "line4": "நடுத்தொழு தேத்துவர் நமச்சி வாயவே."
    },
    {
      "number": 5,
      "line1": "வெந்தநீ றணிவர்வெண் திங்கள் சூடுவர்",
      "line2": "அந்தமில் லாவருள் அழகர் ஆவர்அவ்",
      "line3": "அந்தணர் அரன்நாமம் அஞ்செழுத் தையும்",
      "line4": "சிந்தையில் வைப்பவர் நமச்சி வாயவே."
    },
    {
      "number": 6,
      "line1": "எத்திசை யும்மிறை வன்னென் றெண்ணிநின்று",
      "line2": "ஒப்பிலார் களுமவர் ஒருவன் தன்னையே",
      "line3": "அப்பொழு தடியவர் அடைய நின்றவன்",
      "line4": "செப்பரும் புகழுடை நமச்சி வாயவே."
    },
    {
      "number": 7,
      "line1": "வெற்றிவேற் கண்ணியோர் பங்கன் மெய்த்தவம்",
      "line2": "முற்றுநற் சார்பது வாக முன்னிய",
      "line3": "அற்றவர்க் கற்றவந் தணர்கள் ஓதிவாழ்",
      "line4": "நற்றெரிப் புகழுடை நமச்சி வாயவே."
    },
    {
      "number": 8,
      "line1": "முந்துறு சினத்தினால் முரண்அ ரக்கன்சென்று",
      "line2": "உந்துறு மலையினை எடுக்க ஒண்முடி",
      "line3": "இந்திரன் அனையவன் இறையை ஊன்றலும்",
      "line4": "நந்துதல் அறுப்பது நமச்சி வாயவே."
    },
    {
      "number": 9,
      "line1": "போதிலார் அயனொடு புணர்ந்த மாலினும்",
      "line2": "சோதியார் அறிவரி தாய தோன்றலார்",
      "line3": "ஆதியார் அடியவர்க் கருளும் வண்ணமும்",
      "line4": "நீதியார் அறிவது நமச்சி வாயவே."
    },
    {
      "number": 10,
      "line1": "இலங்கையர் மன்னவன் எடுத்த அடுக்கல்மேல்",
      "line2": "அலங்கலாய் விரலினை அமர ஊன்றலும்",
      "line3": "விலங்கின வாய்பிலாறி அலறி வீழ்ந்தவன்",
      "line4": "நலங்கொள் நாமம்அது நமச்சி வாயவே."
    }
  ]
}
